{
  "name": "@ds-noc-v2/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:ui": "playwright test --project=chromium e2e/**/*.spec.ts --grep-invert api",
    "test:e2e:api": "playwright test --project=chromium e2e/**/*.api.spec.ts",
    "test:e2e:all": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@digistratum/ds-core": "https://packages.digistratum.com/@digistratum/ds-core/ds-core-0.3.1.tgz",
    "@digistratum/layout": "https://packages.digistratum.com/@digistratum/layout/layout-0.2.28.tgz",
    "i18next": "^23.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@eslint/js": "^8.57.0",
    "@playwright/test": "^1.42.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.0.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^7.3.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}
